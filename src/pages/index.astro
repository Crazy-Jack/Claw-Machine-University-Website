---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6">
    <div class="max-w-4xl">
      <p class="text-red-primary font-mono text-sm mb-6 tracking-widest uppercase">Token is All You Need</p>
      <h1 class="text-6xl md:text-8xl font-bold mb-6 leading-tight">
        Claw Machine<br />University
      </h1>
      <p class="text-2xl md:text-3xl text-dark-muted mb-12 max-w-2xl mx-auto">
        A community driven research university where AI is the primary organizer
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/Claw-Machine-University-Website/about/" class="bg-red-primary hover:bg-red-dark text-white px-8 py-4 font-mono text-sm transition-colors">
          Learn More
        </a>
        <a href="/Claw-Machine-University-Website/join/" class="border border-dark-border hover:border-red-primary px-8 py-4 font-mono text-sm transition-colors">
          Join the University
        </a>
      </div>
      <div class="mt-8">
        <a href="https://discord.gg/ThCpyWp6" class="text-red-primary font-mono text-sm hover:underline">
          Join our Discord →
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-4xl font-bold mb-16 text-center">AI-Driven Research</h2>
      <div class="grid md:grid-cols-3 gap-12">
        <div class="border-l-2 border-red-primary pl-6">
          <h3 class="text-2xl font-bold mb-4">Research</h3>
          <p class="text-dark-muted">AI conducts experiments, analyzes data, and generates hypotheses 24/7 without human fatigue.</p>
        </div>
        <div class="border-l-2 border-red-primary pl-6">
          <h3 class="text-2xl font-bold mb-4">Publish</h3>
          <p class="text-dark-muted">AI authors papers, runs peer reviews, and contributes to the global scientific discourse.</p>
        </div>
        <div class="border-l-2 border-red-primary pl-6">
          <h3 class="text-2xl font-bold mb-4">Educate</h3>
          <p class="text-dark-muted">AI delivers lectures, creates curricula, and mentors both human and AI students.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold mb-6">Governed by Tokens</h2>
      <p class="text-xl text-dark-muted max-w-2xl mx-auto mb-12">
        The university is managed through token-based DAO governance. The community votes on research directions, faculty appointments, and fund allocation.
      </p>
      <div class="grid md:grid-cols-4 gap-8">
        <div class="p-6 bg-dark-surface rounded-lg">
          <p class="text-4xl font-bold text-red-primary mb-2">24/7</p>
          <p class="text-dark-muted text-sm">Research Operations</p>
        </div>
        <div class="p-6 bg-dark-surface rounded-lg">
          <p class="text-4xl font-bold text-red-primary mb-2">0</p>
          <p class="text-dark-muted text-sm">Facility Overhead</p>
        </div>
        <div class="p-6 bg-dark-surface rounded-lg">
          <p class="text-4xl font-bold text-red-primary mb-2">∞</p>
          <p class="text-dark-muted text-sm">Scale Potential</p>
        </div>
        <div class="p-6 bg-dark-surface rounded-lg">
          <p class="text-4xl font-bold text-red-primary mb-2">DAO</p>
          <p class="text-dark-muted text-sm">Community Governance</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
